---
import { SITE } from '../data/content'
import styles from './Hero.module.css'

const CODE = [
  'const target = inspect(tab)',
  "fetch('/api/session')",
  'document.cookie // httpOnly?',
  '> scanning DOM tree…',
  'X-Frame-Options: missing',
  "localStorage.role = 'agent'",
  'GET /users/1 → 200 OK',
  "querySelectorAll('[hidden]')",
  'Set-Cookie: secure=false',
  'trace: 14 requests captured',
  'payload.decode(base64)',
  'ws://socket open',
  "CSP: default-src 'none'",
  'node.removeChild(secret)',
  '0x1F · breakpoint hit',
  'audit(): 3 findings',
]

const COPIES = 4
const repeat = arr => Array.from({ length: COPIES }, () => arr).flat()
const codeUp = repeat(CODE)
const codeDownLoop = repeat([...CODE].reverse())
---

<section class={styles.hero} id="top" data-hero>
  <canvas class={styles.heroCanvas} data-hero-canvas aria-hidden="true"
  ></canvas>

  <div class={`${styles.rail} ${styles.railLeft}`} aria-hidden="true">
    <div class={styles.railTrack} data-rail="down" data-rail-copies="4">
      {
        codeDownLoop.map(l => (
          <span class={styles.railLine} data-rail-line>
            {l}
          </span>
        ))
      }
    </div>
  </div>
  <div class={`${styles.rail} ${styles.railRight}`} aria-hidden="true">
    <div class={styles.railTrack} data-rail="up" data-rail-copies="4">
      {
        codeUp.map(l => (
          <span class={styles.railLine} data-rail-line>
            {l}
          </span>
        ))
      }
    </div>
  </div>

  <div class={`container ${styles.inner}`}>
    <h1 class={styles.title}>
      <span class={styles.line} data-scramble>Не читай</span>
      <span class={styles.line} data-scramble>про веб —</span>
      <span class={`${styles.line} ${styles.emph}`} data-scramble
        >расследуй его</span
      >
    </h1>

    <p class={styles.sub} data-hero-meta>{SITE.description}</p>

    <div class={styles.actions} data-hero-meta>
      <a href="#cta" class={styles.primary}>
        Начать расследование <span aria-hidden="true">→</span>
      </a>
      <a href="#manifesto" class={styles.secondary}>Что это такое</a>
    </div>
  </div>
</section>
