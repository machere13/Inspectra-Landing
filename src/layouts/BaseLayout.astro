---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Inspectra — расследуй веб",
  description = "Интерактивная платформа: учись понимать, как реально работает цифровой мир.",
} = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#070707" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="shortcut icon" href="/favicon.ico" />

    <title>{title}</title>

    <link rel="preload" href="/fonts/Geist.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/GeistMono.woff2" as="font" type="font/woff2" crossorigin />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <!-- Фоновая анимация точек (canvas) + статический фолбэк для reduced-motion -->
    <canvas class="bgCanvas" data-bg-canvas aria-hidden="true"></canvas>
    <div class="bgGridFallback" aria-hidden="true"></div>

    <!-- Кастомный курсор -->
    <div class="cursorDot" data-cursor-dot aria-hidden="true"></div>
    <div class="cursorRing" data-cursor-ring aria-hidden="true"></div>

    <!-- Кастомный скролл-индикатор -->
    <div class="scrollProgress" aria-hidden="true">
      <span class="scrollProgressNum" data-progress-num>00</span>
      <span class="scrollProgressTrack">
        <span class="scrollProgressBar" data-progress-bar></span>
      </span>
      <span class="scrollProgressLabel">scroll</span>
    </div>

    <slot />

    <script>
      import "../scripts/motion";
    </script>
  </body>
</html>
