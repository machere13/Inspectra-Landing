---
import '../styles/global.css'
import geistWoff2 from '../fonts/Geist.woff2?url'
import geistMonoWoff2 from '../fonts/GeistMono.woff2?url'

interface Props {
  title?: string
  description?: string
}

const {
  title = 'Инспектра — расследуй веб',
  description = 'Интерактивная платформа: учись понимать, как реально работает цифровой мир.',
} = Astro.props

const base = import.meta.env.BASE_URL
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#070707" />

    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="icon" type="image/png" sizes="96x96" href={`${base}favicon-96x96.png`} />
    <link rel="shortcut icon" href={`${base}favicon.ico`} />

    <title>{title}</title>

    <link rel="preload" href={geistWoff2} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={geistMonoWoff2} as="font" type="font/woff2" crossorigin />


    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <canvas class="bgCanvas" data-bg-canvas aria-hidden="true"></canvas>
    <div class="bgGridFallback" aria-hidden="true"></div>

    <div class="cursorDot" data-cursor-dot aria-hidden="true"></div>
    <div class="cursorRing" data-cursor-ring aria-hidden="true"></div>

    <div class="scrollProgress" aria-hidden="true">
      <span class="scrollProgressNum" data-progress-num>00</span>
      <span class="scrollProgressTrack">
        <span class="scrollProgressBar" data-progress-bar></span>
      </span>
      <span class="scrollProgressLabel">прокрутка</span>
    </div>

    <slot />

    <script>
      import '../scripts/motion'
    </script>
  </body>
</html>
